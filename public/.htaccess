# ==========================================
# 0. PROTECT SENSITIVE LOG FILES
# ==========================================
<Files "landing_error.log">
    Require all denied
</Files>

# ==========================================
# 1. CORE MVC ROUTING RULES (DO NOT REMOVE)
# ==========================================
<IfModule mod_rewrite.c>
    Options -Multiviews
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ index.php?url=$1 [L,QSA]
</IfModule>

# ==========================================
# 2. PRAGMATIC HTTP SECURITY HEADERS
# ==========================================
<IfModule mod_headers.c>
    # Prevent Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-sniffing
    Header set X-Content-Type-Options "nosniff"

    # Enforce HTTPS (HSTS)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Control Referrer Information
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Balanced CSP: Allows inline scripts/styles for UI functionality but restricts objects and iframes
    # Note: connect-src explicitly allows calls to the Admin API
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; img-src 'self' data: https: blob:; connect-src 'self' https://adminpju.dishubsleman.id https:; object-src 'none'; base-uri 'none'; frame-ancestors 'none';"

    # Permissions-Policy: allow only camera (QR scanner) and fullscreen (Html5Qrcode mobile UI).
    # All other sensitive hardware/browser APIs are explicitly denied.
    Header set Permissions-Policy "camera=(self), fullscreen=(self), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=(), ambient-light-sensor=(), midi=(), nfc=(), hid=(), serial=(), battery=(), gamepad=(), display-capture=(), idle-detection=(), screen-wake-lock=(), speaker-selection=(), xr-spatial-tracking=(), publickey-credentials-create=(), publickey-credentials-get=(), identity-credentials-get=(), window-management=(), local-fonts=(), encrypted-media=(), picture-in-picture=(), autoplay=(), document-domain=()"
</IfModule>
