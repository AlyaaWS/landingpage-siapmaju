# ==========================================
# 1. CORE MVC ROUTING RULES (DO NOT REMOVE)
# ==========================================
<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On
    RewriteBase /landingpage-siapmaju/public

    # Do not route if the request is for an existing physical file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else to index.php
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

# ==========================================
# 2. PRAGMATIC HTTP SECURITY HEADERS
# ==========================================
<IfModule mod_headers.c>
    # Prevent Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-sniffing
    Header set X-Content-Type-Options "nosniff"

    # Enforce HTTPS (HSTS)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Control Referrer Information
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Balanced CSP: Allows inline scripts/styles for UI functionality but restricts objects and iframes
    # Note: connect-src explicitly allows calls to the Admin API
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; img-src 'self' data: https: blob:; connect-src 'self' https://adminpju.dishubsleman.id https:; object-src 'none'; base-uri 'none'; frame-ancestors 'none';"
</IfModule>
